<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8">
    <title>GitHealth - {{ repository }}</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: #16202a;
        background: #f5f7f9;
      }
      body {
        margin: 0;
      }
      header {
        background: #1f4f46;
        color: white;
        padding: 32px max(24px, calc((100vw - 1120px) / 2));
      }
      main {
        max-width: 1120px;
        margin: 0 auto;
        padding: 24px;
      }
      section {
        margin: 28px 0;
      }
      h1, h2 {
        margin: 0 0 12px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
      }
      .metric {
        background: white;
        border: 1px solid #d7dde2;
        border-radius: 8px;
        padding: 16px;
      }
      .metric strong {
        display: block;
        font-size: 28px;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        background: white;
        border: 1px solid #d7dde2;
      }
      th, td {
        padding: 10px 12px;
        border-bottom: 1px solid #e7eaee;
        text-align: left;
      }
      th {
        background: #eef2f4;
      }
      .chart {
        background: white;
        border: 1px solid #d7dde2;
        border-radius: 8px;
        padding: 10px;
      }
      .muted {
        color: #5c6873;
      }
    </style>
  </head>
  <body>
    <header>
      <h1>GitHealth</h1>
      <p>Analise historica de gargalos de revisao em {{ repository }}</p>
    </header>
    <main>
      <section class="grid">
        <div class="metric"><span>Pull requests</span><strong>{{ metrics|length }}</strong></div>
        <div class="metric"><span>Hotspots</span><strong>{{ hotspots|selectattr("sample_sufficient")|list|length }}</strong></div>
        <div class="metric"><span>Associacoes</span><strong>{{ correlations|length }}</strong></div>
      </section>

      <section>
        <h2>Graficos</h2>
        {% if scatter_chart %}<div class="chart">{{ scatter_chart|safe }}</div>{% endif %}
        {% if hotspot_chart %}<div class="chart">{{ hotspot_chart|safe }}</div>{% endif %}
      </section>

      <section>
        <h2>Correlacoes</h2>
        <p class="muted">As correlacoes indicam associacoes historicas, nao causalidade.</p>
        <table>
          <thead><tr><th>Caracteristica</th><th>Resultado</th><th>Spearman</th><th>Interpretacao</th></tr></thead>
          <tbody>
            {% for item in correlations %}
              <tr>
                <td>{{ item.feature }}</td>
                <td>{{ item.outcome }}</td>
                <td>{{ item.coefficient if item.coefficient is not none else "n/a" }}</td>
                <td>{{ item.description }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Hotspots de arquivos</h2>
        <table>
          <thead><tr><th>Arquivo</th><th>PRs</th><th>Mediana ciclo</th><th>Esforco</th><th>Amostra</th></tr></thead>
          <tbody>
            {% for item in hotspots[:20] %}
              <tr>
                <td>{{ item.filename }}</td>
                <td>{{ item.pull_requests }}</td>
                <td>{{ item.median_cycle_hours if item.median_cycle_hours is not none else "sem dados" }}</td>
                <td>{{ item.median_review_effort }}</td>
                <td>{{ "suficiente" if item.sample_sufficient else "insuficiente" }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      </section>

      <section>
        <h2>Pull requests com maior tempo</h2>
        <table>
          <thead><tr><th>PR</th><th>Titulo</th><th>Estado</th><th>Arquivos</th><th>Churn</th><th>Ciclo h</th><th>Esforco</th></tr></thead>
          <tbody>
            {% for item in metrics|sort(attribute="cycle_hours", reverse=true) %}
              {% if loop.index <= 20 %}
                <tr>
                  <td>#{{ item.number }}</td>
                  <td>{{ item.title }}</td>
                  <td>{{ item.state }}</td>
                  <td>{{ item.changed_files }}</td>
                  <td>{{ item.churn }}</td>
                  <td>{{ item.cycle_hours if item.cycle_hours is not none else "sem dados" }}</td>
                  <td>{{ item.review_effort_index }}</td>
                </tr>
              {% endif %}
            {% endfor %}
          </tbody>
        </table>
      </section>
    </main>
  </body>
</html>
